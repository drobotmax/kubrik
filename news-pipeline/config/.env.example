# kubrik-news config
# Copy to .env: cp .env.example .env

# ---- RSS Feeds (official platform blogs) ----
# Format: NAME|URL|PLATFORM
# Pipe-separated: display name, RSS URL, platform tag

NEWS_RSS_FEEDS="
Google Ads Blog|https://blog.google/products/ads-commerce/rss/|google
Yandex Ads News|https://yandex.ru/adv/news/rss|yandex
"

# Meta Business News - no working RSS, parsed via HTML scraping
NEWS_HTML_SOURCES="
Meta Business|https://www.facebook.com/business/news|meta
"

# ---- Telegram channels (parsed via telegram-channel-parser) ----
# Comma-separated usernames (without @)
NEWS_TG_CHANNELS=paborobot,directorologia,targetolog,caborobot

# ---- Filter keywords (for relevance scoring) ----
# Comma-separated, case-insensitive
NEWS_KEYWORDS="ads,advertising,campaign,targeting,bidding,audience,conversion,pixel,API,deprecat,policy,update,launch,beta,new_feature,real_estate,lead_gen,performance_max,advantage+,demand_gen,smart_bidding"

# ---- Digest settings ----
NEWS_DIGEST_PERIOD=7
NEWS_DIGEST_MAX_ITEMS=50
